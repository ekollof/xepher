#!/usr/bin/make -f

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@

override_dh_auto_build:
	[ -f deps/diff/Makefile ] || git submodule update --init --recursive
	$(MAKE) weechat-xmpp

override_dh_auto_clean:
	$(MAKE) clean || true

override_dh_auto_test:
	# Skip tests for now
